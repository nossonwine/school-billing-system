// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
url      = env("DATABASE_URL")
}

// --- CLASS & FEES SETTINGS ---
model ClassSetting {
  id          String   @id @default(cuid())
  periodNum   Int      @unique
  hebrewName  String
  durationMin Int
  orderIndex  Int      @default(0)
}

model GlobalSetting {
  id           String @id @default(cuid())
  absenceFee   Float  @default(5.00)
  lateTier1Fee Float  @default(1.00)
  testFailFee  Float  @default(10.00)
}

// --- STUDENT DIRECTORY ---
model Student {
  id         String     @id @default(cuid())
  name       String     @unique
  exemptions String?
  incidents  Incident[]
  user       User?      // This invisible wire connects the student to their parent's login
}

// --- CHARGES & INCIDENTS ---
model Incident {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date          DateTime
  className     String
  type          String
  feeCalculated Float?
  amountPaid    Float    @default(0)
  isExcused     Boolean  @default(false)
  notes         String?
  isShared      Boolean  @default(false) // This is the new "lock" that hides charges from parents
}

// --- NEW PARENT & ADMIN LOGINS ---
model User {
  id        String   @id @default(cuid())
  username  String   @unique 
  password  String
  role      String   @default("PARENT") // Tells the system if they are an ADMIN or PARENT
  studentId String?  @unique
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
}